---
import Layout from '../../layouts/Layout.astro';
import type { Product } from '../../store/cartStore';

// Enable SSR for this page
export const prerender = false;

const { id } = Astro.params;

// ─── Fetch Product from API ──────────────────────────────────────────────────
let product: Product | null = null;
let fetchError = null;

try {
  const apiUrl = import.meta.env.PUBLIC_SHEETS_API;
  const response = await fetch(apiUrl);
  if (!response.ok) throw new Error(`Status: ${response.status}`);
  const rawData = await response.json();
  
  // Find product by ID
  const found = (rawData ?? []).find((p: any) => String(p.id ?? p.ID) === id);
  
  if (found) {
    product = {
      id: String(found.id ?? found.ID),
      name: found.nombre ?? found.name ?? 'Producto ELITE',
      price: Number(found.precio ?? found.price ?? 0),
      category: found.categoria ?? found.category ?? 'Colección',
      image: found.imagen_url ?? found.image ?? 'https://images.unsplash.com/photo-1551028719-00167b16eac5?w=600&q=80',
      description: found.descripcion ?? found.description ?? 'Sin descripción disponible.',
      variantes: typeof found.variantes === 'string' ? JSON.parse(found.variantes) : (found.variantes ?? []),
    };
  }
} catch (error: any) {
  console.error('[API] Error fetching product detail:', error.message);
  fetchError = error.message;
}

if (!product && !fetchError) {
  return Astro.redirect('/404');
}
---

<Layout title={product ? `${product.name} | ELITE` : 'Cargando...'} description={product?.description}>
  <div class="pt-24 lg:pt-32 pb-24 max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-start">
      
      <!-- ─── Image Gallery Section ──────────────────────────────── -->
      <div class="space-y-6">
        <div class="aspect-[4/5] overflow-hidden bg-neutral-100 ring-1 ring-neutral-200">
          {product && (
            <img 
              src={product.image} 
              alt={product.name} 
              class="w-full h-full object-cover"
              style={`view-transition-name: img-${product.id}`}
            />
          )}
        </div>
        
        {/* Mock secondary images */}
        <div class="grid grid-cols-3 gap-4">
          {[1,2,3].map(i => (
             <div class="aspect-square bg-neutral-100 overflow-hidden ring-1 ring-neutral-200 hover:opacity-80 transition-opacity cursor-pointer">
                <img src={product?.image} alt="Gallery" class="w-full h-full object-cover grayscale opacity-50" />
             </div>
          ))}
        </div>
      </div>

      <!-- ─── Info Section ────────────────────────────────────────── -->
      <div class="lg:sticky lg:top-32">
        <nav class="flex items-center gap-2 mb-8 text-xs tracking-widest uppercase text-neutral-400">
           <a href="/" class="hover:text-neutral-900 transition-colors">Inicio</a>
           <span>/</span>
           <span class="text-neutral-600 font-medium">{product?.category}</span>
        </nav>

        <h1 class="text-4xl md:text-5xl font-light text-neutral-900 tracking-tight leading-tight mb-4">
          {product?.name}
        </h1>
        
        <p class="text-2xl font-light text-neutral-700 mb-8">
           €{product?.price.toLocaleString('es-ES', { minimumFractionDigits: 2 })}
        </p>

        <div class="h-px bg-neutral-100 mb-8" />

        <div class="prose prose-neutral prose-sm mb-12">
            <h3 class="text-xs font-semibold tracking-widest uppercase text-neutral-900 mb-4">Descripción</h3>
            <p class="text-neutral-500 leading-relaxed">
              {product?.description}
            </p>
        </div>

        <!-- Add to Cart Widget (React) -->
        <div class="space-y-8">
          {product && (
            <button
               id="add-to-cart-page"
               data-product={JSON.stringify(product)}
               class="w-full py-5 bg-neutral-900 text-white text-xs font-bold tracking-[0.2em] uppercase hover:bg-neutral-800 transition-all active:scale-[0.98] shadow-xl shadow-neutral-900/10"
            >
               Añadir a la Selección
            </button>
          )}
          
          <div class="grid grid-cols-2 gap-4">
             <div class="border border-neutral-100 p-4 rounded-sm">
                <p class="text-[10px] font-bold uppercase tracking-wider text-neutral-400 mb-1">Envío</p>
                <p class="text-xs text-neutral-600">Gratis en órdenes Elite</p>
             </div>
             <div class="border border-neutral-100 p-4 rounded-sm">
                <p class="text-[10px] font-bold uppercase tracking-wider text-neutral-400 mb-1">Garantía</p>
                <p class="text-xs text-neutral-600">2 años de excelencia</p>
             </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { addToCart, isCartOpen } from '../../store/cartStore';

  function initPage() {
    const btn = document.getElementById('add-to-cart-page');
    if (!btn) return;

    btn.addEventListener('click', () => {
      const productData = btn.getAttribute('data-product');
      if (!productData) return;
      
      const product = JSON.parse(productData);
      addToCart({
        id: product.id,
        name: product.name,
        price: product.price,
        image: product.image,
        category: product.category,
      });
      isCartOpen.set(true);
    });
  }

  // Initialize on first load and on navigation
  document.addEventListener('astro:page-load', initPage);
</script>
