---
import Layout from '../../layouts/Layout.astro';
import { getProductById } from '../../data/productos';
import type { Product } from '../../store/cartStore';

const { id } = Astro.params;
const product: Product | undefined = getProductById(id as string);

if (!product) {
  return Astro.redirect('/404');
}

// Category → category page URL mapping
const categoryHref: Record<string, string> = {
  gorras: '/gorras',
  camisetas: '/camisetas',
  pantalones: '/pantalones',
};
---

<Layout
  title={`${product.name} | ELITE`}
  description={product.description ?? `${product.name} — pieza de alta calidad ELITE.`}
>
  <div class="pt-24 lg:pt-32 pb-24 max-w-7xl mx-auto px-6 lg:px-10">
    <div class="grid lg:grid-cols-2 gap-16 lg:gap-24 items-start">

      <!-- ─── Image Gallery ─────────────────────────────────────── -->
      <div class="space-y-6">
        <div class="aspect-[4/5] overflow-hidden bg-neutral-100">
          <img
            src={product.image}
            alt={`${product.name} — ELITE`}
            class="w-full h-full object-cover"
            style={`view-transition-name: img-${product.id}`}
          />
        </div>

        <!-- Secondary thumbnails (same image as placeholder) -->
        <div class="grid grid-cols-3 gap-4">
          {[1, 2, 3].map(i => (
            <div class="aspect-square bg-neutral-100 overflow-hidden hover:opacity-80 transition-opacity cursor-pointer">
              <img
                src={product.image}
                alt={`${product.name} vista ${i}`}
                class="w-full h-full object-cover grayscale opacity-50"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>

      <!-- ─── Product Info ──────────────────────────────────────── -->
      <div class="lg:sticky lg:top-32">
        <!-- Breadcrumb -->
        <nav class="flex items-center gap-2 mb-8 text-xs tracking-widest uppercase text-neutral-400" aria-label="Breadcrumb">
          <a href="/" title="Inicio ELITE" class="hover:text-neutral-900 elite-transition">Inicio</a>
          <span>/</span>
          <a
            href={categoryHref[product.category] ?? '/'}
            title={`Colección ${product.category}`}
            class="hover:text-neutral-900 elite-transition capitalize"
          >
            {product.category}
          </a>
          <span>/</span>
          <span class="text-neutral-600 font-medium truncate max-w-[160px]">{product.name}</span>
        </nav>

        <h1 class="text-4xl md:text-5xl font-light text-neutral-900 tracking-tight leading-tight mb-4">
          {product.name}
        </h1>

        <p class="text-2xl font-light text-neutral-700 mb-8">
          €{product.price.toLocaleString('es-ES', { minimumFractionDigits: 2 })}
        </p>

        <div class="h-px bg-neutral-100 mb-8"></div>

        <!-- Description -->
        <div class="mb-10">
          <h2 class="text-xs font-semibold tracking-widest uppercase text-neutral-900 mb-4">Descripción</h2>
          <p class="text-neutral-500 leading-relaxed text-sm">{product.description}</p>
        </div>

        <!-- Variants info if any -->
        {product.variantes && product.variantes.length > 0 && (
          <div class="mb-10">
            <h2 class="text-xs font-semibold tracking-widest uppercase text-neutral-900 mb-4">Disponible en</h2>
            <div class="flex flex-wrap gap-2">
              {[...new Set(product.variantes.map(v => v.size ?? v.color ?? ''))].map(val => (
                <span class="px-3 py-1.5 border border-neutral-200 text-xs text-neutral-600 capitalize">{val}</span>
              ))}
            </div>
          </div>
        )}

        <!-- Add to Cart -->
        <div class="space-y-6">
          <button
            id="add-to-cart-page"
            data-product={JSON.stringify(product)}
            class="w-full py-5 bg-neutral-900 text-white text-xs font-bold tracking-[0.2em] uppercase hover:bg-neutral-800 elite-transition active:scale-[0.98]"
          >
            Añadir a la Selección
          </button>

          <div class="grid grid-cols-2 gap-4">
            <div class="border border-neutral-100 p-4">
              <p class="text-[10px] font-bold uppercase tracking-wider text-neutral-400 mb-1">Envío</p>
              <p class="text-xs text-neutral-600">Gratis en pedidos +€200</p>
            </div>
            <div class="border border-neutral-100 p-4">
              <p class="text-[10px] font-bold uppercase tracking-wider text-neutral-400 mb-1">Garantía</p>
              <p class="text-xs text-neutral-600">2 años de excelencia</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>
</Layout>

<script>
  import { addToCart, isCartOpen, selectedProduct } from '../../store/cartStore';

  function initPage() {
    const btn = document.getElementById('add-to-cart-page');
    if (!btn) return;

    btn.addEventListener('click', () => {
      const raw = btn.getAttribute('data-product');
      if (!raw) return;
      const product = JSON.parse(raw);

      if (product.variantes && product.variantes.length > 0) {
        selectedProduct.set(product);
      } else {
        addToCart({
          id: product.id,
          name: product.name,
          price: product.price,
          image: product.image,
          category: product.category,
        });
        isCartOpen.set(true);
      }
    });
  }

  document.addEventListener('astro:page-load', initPage);
</script>
